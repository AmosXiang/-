        lines {
          text: "                  .reverse()"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  .find((shot) => shot.timeSeconds <= targetSeconds);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
