          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                const rect = e.currentTarget.getBoundingClientRect();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                const clickX = e.clientX - rect.left;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                const percentage = clickX / rect.width;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                const targetSeconds = Math.floor(percentage * maxDuration);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                setCurrentTime(targetSeconds);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
