# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Agnes Video V2.0 text-to-video provider. Never commit a real key.
AGNES_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FFmpeg executable name or absolute path. Required for animatic compilation.
# On Windows, use forward slashes in .env paths (for example C:/ffmpeg/bin/ffmpeg.exe).
FFMPEG_PATH="ffmpeg"

# Local ComfyUI image generation. The standard ComfyUI port is 8188.
COMFYUI_API_URL="http://127.0.0.1:8188"
COMFYUI_TIMEOUT_SECONDS="300"
COMFYUI_MAX_IMAGE_MB="30"

# Leave blank to use the first checkpoint reported by ComfyUI.
COMFYUI_CKPT_NAME=""
COMFYUI_STEPS="24"
COMFYUI_CFG="7"
COMFYUI_SAMPLER="euler"
COMFYUI_SCHEDULER="normal"

# Optional: API-format workflow path, relative to the project root.
COMFYUI_WORKFLOW_PATH="comfyui_workflow.json"

# Optional custom-workflow node mapping. Auto-detection is used when blank.
COMFYUI_PROMPT_NODE_ID=""
COMFYUI_NEGATIVE_NODE_ID=""
COMFYUI_SEED_NODE_ID=""
COMFYUI_CKPT_NODE_ID=""
COMFYUI_LATENT_NODE_ID=""

# ComfyUI process management settings
COMFYUI_MANAGED_LAUNCH_ENABLED=true
COMFYUI_EXECUTABLE=
COMFYUI_WORKDIR=
COMFYUI_ARGS_JSON=[]
COMFYUI_AUTOSTART=false
COMFYUI_START_TIMEOUT_MS=120000
