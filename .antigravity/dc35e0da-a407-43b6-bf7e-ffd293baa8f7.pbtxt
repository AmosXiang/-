\\\">\346\225\205\344\272\213\347\273\223\346\236\204</label>\\n            <p class=\\\"text-sm text-slate-200\\\">\347\273\217\345\205\270\344\270\211\346\256\265\345\274\217\347\273\223\346\236\204\343\200\202\345\274\200\345\244\264\351\200\232\350\277\207\346\202\254\345\277\265\345\220\270\345\274\225\350\247\202\344\274\227\357\274\214\344\270\255\346\234\237\351\200\232\350\277\207\345\257\206\351\233\206\347\232\204\350\247\206\350\247\211\345\206\262\347\252\201\347\273\264\346\214\201\347\203\255\345\272\246\357\274\214\347\273\223\345\260\276\347\225\231\347\231\275\345\274\225\344\272\272\346\267\261\346\200\235\343\200\202</p>\\n          </div>\\n          <div class=\\\"grid grid-cols-2 gap-3\\\">\\n            <div class=\\\"bg-slate-800/40 p-3 rounded-lg border border-slate-700/50\\\">\\n              <label class=\\\"text-[10px] text-slate-500 uppercase block mb-1\\\">\350\212\202\345\245\217\347\211\271\347\202\271</label>\\n              <p class=\\\"text-sm text-slate-200\\\">\345\277\253\350\212\202\345\245\217\345\211\252\350\276\221\357\274\214\345\271\263\345\235\207\351\225\234\345\244\264\346\227\266\351\225\277\344\273\205 2.4s\343\200\202</p>\\n            </div>\\n            <div class=\\\"bg-slate-800/40 p-3 rounded-lg border border-slate-700/50\\\">\\n              <label class=\\\"text-[10px] text-slate-500 uppercase block mb-1\\\">\347\210\275\347\202\271\350\256\276\350\256\241</label>\\n              <p class=\\\"text-sm text-slate-200\\\">\350\247\206\350\247\211\345\245\207\350\247\202\344\270\216\351\237\263\346\225\210\347\232\204\351\253\230\345\220\214\346\255\245\347\210\206\345\217\221\347\202\271\343\200\202</p>\\n            </div>\\n          </div>\\n        </div>\\n      </div>\\n\\n      <!-- Characters Section -->\\n      <div class=\\\"p-6 flex-1 flex flex-col\\\">\\n        <h2 class=\\\"text-xs font-bold text-purple-400 uppercase tracking-widest mb-4 flex items-center\\\">\\n          <span class=\\\"w-2 h-2 bg-purple-400 rounded-full mr-2\\\"></span> \350\247\222\350\211\262\347\224\273\345\203\217 (Characters)\\n        </h2>\\n        <div class=\\\"space-y-3\\\">\\n          <div class=\\\"flex items-start gap-4 p-3 bg-slate-800/60 rounded-xl border border-slate-700/50\\\">\\n            <div class=\\\"w-12 h-12 bg-slate-700 rounded-full flex-shrink-0 flex items-center justify-center border border-white/10 overflow-hidden text-lg font-bold text-slate-500\\\">A</div>\\n            <div>\\n              <div class=\\\"flex items-center gap-2 mb-1\\\">\\n                <h3 class=\\\"text-sm font-bold text-white\\\">\346\236\227\346\267\261 (\344\276\246\346\216\242)</h3>\\n                <span class=\\\"text-[10px] px-2 py-0.5 bg-purple-900/50 text-purple-200 rounded-full border border-purple-700/50\\\">\346\240\270\345\277\203\344\270\273\350\247\222</span>\\n              </div>\\n              <p class=\\\"text-xs text-slate-400\\\">\346\200\247\346\240\274\357\274\232\346\262\211\347\235\200\343\200\201\346\225\217\351\224\220\357\274\214\345\270\246\346\234\211\346\230\216\346\230\276\347\232\204\347\244\276\344\272\244\347\226\217\347\246\273\346\204\237\343\200\202</p>\\n              <p class=\\\"text-[11px] text-slate-500 mt-1 italic\\\">\346\234\215\350\243\205\357\274\232\346\267\261\347\201\260\347\243\250\347\240\202\347\232\256\350\241\243\357\274\214\351\273\221\350\211\262\351\253\230\351\242\206\345\206\205\346\220\255\357\274\214\347\225\245\346\230\276\345\207\214\344\271\261\347\232\204\351\273\221\345\217\221\343\200\202</p>\\n            </div>\\n          </div>\\n          <div class=\\\"flex items-start gap-4 p-3 bg-slate-800/60 rounded-xl border border-slate-700/50\\\">\\n            <div class=\\\"w-12 h-12 bg-slate-700 rounded-full flex-shrink-0 flex items-center justify-center border border-white/10 overflow-hidden text-lg font-bold text-slate-500\\\">B</div>\\n            <div>\\n              <div class=\\\"flex items-center gap-2 mb-1\\