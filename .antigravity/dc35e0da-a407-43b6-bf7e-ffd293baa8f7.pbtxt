\203\205\347\273\252\": \"\345\243\256\344\270\275\343\200\201\346\236\201\350\207\264\347\232\204\347\276\216\346\204\237\344\270\216\345\257\271\346\234\252\347\237\245\345\206\222\351\231\251\347\232\204\346\234\237\345\276\205\"\n    },\n    {\n      \"\346\227\266\351\227\264\346\210\263\": \"00:07 - 00:27\",\n      \"\350\277\220\351\225\234\": \"\346\216\250\346\213\211\351\225\234\345\244\264 (Push-Pull Shot), \350\202\251\351\203\250\351\225\234\345\244\264 (Over-the-shoulder)\",\n      \"\346\236\204\345\233\276\": \"\350\277\221\346\231\257\350\241\250\346\203\205\347\211\271\345\206\231\357\274\214\350\247\206\350\247\211\351\207\215\345\277\203\357\274\214\351\207\221\345\261\236\351\227\250\346\241\206\345\222\214\350\210\261\345\206\205\347\251\272\351\227\264\",\n      \"\346\203\205\347\273\252\": \"\350\257\231\350\260\220\343\200\201\345\271\275\351\273\230\"\n    },\n    {\n      \"\346\227\266\351\227\264\346\210\263\": \"01:56 - 02:07\",\n      \"\350\277\220\351\225\234\": \"\350\207\252\347\224\261\350\220\275\344\275\223\350\264\264\350\272\253\350\267\237\346\213\215 (Free-fall Tracking) \344\270\216\345\234\260\351\235\242\344\273\260\350\247\222\350\213\261\351\233\204\350\247\206\347\202\271\",\n      \"\346\236\204\345\233\276\": \"\345\212\250\346\200\201\346\224\276\345\260\204\347\272\277\346\236\204\345\233\276\357\274\214\345\260\221\345\245\263\345\236\202\347\233\264\344\277\257\345\206\262\357\274\214\346\236\201\345\205\267\345\212\250\346\200\201\345\274\240\345\212\233\",\n      \"\346\203\205\347\273\252\": \"\346\203\212\351\231\251\343\200\201\345\210\272\346\277\200\343\200\201\350\261\252\346\224\276\343\200\201\345\261\225\347\216\260\345\260\221\345\245\263\345\206\267\351\205\267\344\274\230\351\233\205\347\232\204\350\266\205\345\207\241\350\203\206\350\257\206\"\n    },\n    {\n      \"\346\227\266\351\227\264\346\210\263\": \"02:07 - 02:25\",\n      \"\350\277\220\351\225\234\": \"\346\200\245\351\200\200\346\216\2