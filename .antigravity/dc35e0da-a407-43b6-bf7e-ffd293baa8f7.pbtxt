  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect, useRef } from \"react\";\nimport { \n  Play, \n  Pause, \n  Download, \n  Copy, \n  Search, \n  Tv, \n  Film, \n  Users, \n  Sparkles, \n  Cpu, \n  Layers, \n  Check, \n  Clock, \n  ChevronRight, \n  Share2, \n  Database,\n  Sliders,\n  FileJson,\n  X,\n  Volume2,\n  VolumeX,\n  Monitor\n} from \"lucide-react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { videoAnalysisData } from \"./data\";\nimport { Shot, Character } from \"./types\";\n\nexport default function App() {\n  const [activeShot, setActiveShot] = useState<Shot>(videoAnalysisData.shots[0]);\n  const [isPlaying, setIsPlaying] = useState<boolean>(false);\n  const [currentTime, setCurrentTime] = useState<number>(0);\n  const [searchQuery, setSearchQuery] = useState<string>(\"\");\n  const [selectedCharacter, setSelectedCharacter] = useState<Character | null>(null);\n  const [showJsonModal, setShowJsonModal] = useState<boolean>(false);\n  const [copied, setCopied] = useState<boolean>(false);\n  const [audioMuted, setAudioMuted] = useState<boolean>(true);\n  const [activeTab, setActiveTab] = useState<\"narrative\" | \"shots\" | \"characters\">(\"shots\");\n  const [filterCategory, setFilterCategory] = useState<string>(\"all\");\n\n  const timelineInterval = useRef<NodeJS.Timeout | null>(null);\n  const maxDuration = 337; // 5 mins 37 seconds total = 337 seconds\n\n  // Handle timeline simulation playback\n  useEffect(() => {\n    if (isPlaying) {\n      timelineInterval.current = setInterval(() => {\n        setCurrentTime((prev) => {\n          const next = prev + 1;\n          if (next >= maxDuration) {\n            setIsPlaying(false);\n            return 0;\n          }\n          // Find if there is a matching shot for the current time in seconds\n          const matchingShot = [...videoAnalysisData.shots]\n            .reverse()\n            .find((shot) => shot.timeSeconds <= next);\n          if (matchingShot && matchingShot.id !== activeShot.id) {\n            setActiveShot(matchingShot);\n          }\n          return next;\n        });\n      }, 1000);\n    } else {\n      if (timelineInterval.current) {\n        clearInterval(timelineInterval.current);\n      }\n    }\n\n    return () => {\n      if (timelineInterval.current) {\n        clearInterval(timelineInterval.current);\n      }\n    };\n  }, [isPlaying, activeShot]);\n\n  // Jump playhead to specific shot\n  const handleShotClick = (shot: Shot) => {\n    setActiveShot(shot);\n    setCurrentTime(shot.timeSeconds);\n    // If playing, keep playing from there\n  };\n\n  const formatTime = (totalSeconds: number) => {\n    const minutes = Math.floor(totalSeconds / 60);\n    const seconds = totalSeconds % 60;\n    return `${minutes.toString().padStart(2, \"0\")}:${seconds.toString().padStart(2, \"0\")}`;\n  };\n\n  // Filter shots based on search query or category\n  const filteredShots = videoAnalysisData.shots.filter((shot) => {\n    const matchesSearch = \n      shot.timestamp.includes(searchQuery) ||\n      shot.movement.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      shot.composition.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      shot.emotion.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      shot.description.toLowerCase().includes(searchQuery.toLowerCase());\n\n    if (filterCategory === \"all\") return matchesSearch;\n    if (filterCategory === \"aerial\") return matchesSearch && shot.movement.includes(\"\350\210\252\346\213\215\");\n    if (filterCategory === \"close\") return matchesSearch && shot.movement.includes(\"\347\211\271\345\206\231\");\n    if (filterCategory === \"portal\") return matchesSearch && (shot.description.includes(\"\351\227\250\") || shot.description.includes(\"\347\251\277\"));\n    return matchesSearch;\n  });\n\n  // Raw requested JSON output in Chinese\n  const formattedJsonData = {\n    shots: videoAnalysisData.shots.map(s => ({\n      \"\346\227\266\351\227\264\346\210\263\": s.timestamp,\n      \"\350\277\220\351\225\234\": s.movement,\n      \"\346\236\204\345\233\276\": s.composition,\n      \"\346\203\205\347\273\252\": s.emotion\n    })),\n    characters: videoAnalysisData.characters.map(c => ({\n      \"\345\247\223\345\220\215/\344\273\243\345\217\267\": c.name,\n      \"\346\200\247\346\240\274\347\211\271\345\276\201\": c.personality,\n      \"\346\234\215\350\243\205\": c.clothing\n    })),\n    narrative: {\n      \"\346\225\205\344\272\213\347\273\223\346\236\204\": videoAnalysisData.narrative.structure,\n      \"\350\212\202\345\245\217\347\211\271\347\202\271\": videoAnalysisData.narrative.rhythm,\n      \"\347\210\275\347\202\271\350\256\276\350\256\241\": videoAnalysisData.narrative.climaxDesign\n    }\n  };\n\n  const jsonString = JSON.stringify(formattedJsonData, null, 2);\n\n  const handleCopyJson = () => {\n    navigator.clipboard.writeText(jsonString);\n    setCopied(true);\n    setTimeout(() => setCopied(false), 2000);\n  };\n\n  const handleDownloadJson = () => {\n    const element = document.createElement(\"a\");\n    const file = new Blob([jsonString], { type: \"application/json\" });\n    element.href = URL.createObjectURL(file);\n    element.download = \"video_analysis_report.json\";\n    document.body.appendChild(element);\n    element.click();\n    document.body.removeChild(element);\n  };\n\n  return (\n    <div className=\"bg-slate-950 text-slate-200 min-h-screen flex flex-col font-sans select-none overflow-x-hidden antialiased\">\n      {/* Top Header */}\n      <header className=\"h-14 border-b border-slate-800/80 flex items-center justify-between px-6 bg-slate-900/60 backdrop-blur-md sticky top-0 z-40\">\n        <div className=\"flex items-center gap-4\">\n          <div className=\"w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center font-bold text-white shadow-md shadow-blue-900/20\">\n            <Film className=\"w-4 h-4 text-white\" />\n          </div>\n          <div>\n            <h1 className=\"text-sm md:text-base font-semibold tracking-tight flex items-center gap-2\">\n              \350\247\206\351\242\221\346\231\272\350\203\275\345\210\206\346\236\220\345\267\245\344\275\234\345\217\260 \n              <span className=\"text-slate-500 font-normal text-xs bg-slate-800 px-2 py-0.5 rounded-full border border-slate-700/50\">Pro_Edit_Final_V4.mp4</span>\n            </h1>\n          </div>\n        </div>\n        <div className=\"flex items-center gap-3\">\n          <span className=\"hidden sm:inline-flex items-center gap-1.5 text-xs font-mono bg-emerald-950/40 text-emerald-400 border border-emerald-800/50 px-2.5 py-0.5 rounded-full\">\n            <span className=\"w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse\"></span>\n            ANALYSIS READY\n          </span>\n          <button \n            id=\"export-json-btn\"\n            onClick={() => setShowJsonModal(true)}\n            className=\"bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white text-xs font-medium py-1.5 px-3 md:px-4 rounded-md transition-all flex items-center gap-2 cursor-pointer shadow-lg shadow-blue-900/15\"\n          >\n            <FileJson className=\"w-3.5 h-3.5\" />\n            <span>\345\257\274\345\207\272 JSON \346\212\245\345\221\212</span>\n          </button>\n        </div>\n      </header>\n\n      {/* Main Workspace Area */}\n      <main className=\"flex-1 flex flex-col lg:flex-row overflow-hidden max-w-[1600px] w-full mx-auto\">\n        \n        {/* Left Column: Player & Active Shot (Desktop 620px or flex-1) */}\n        <section className=\"w-full lg:w-[640px] xl:w-[700px] flex flex-col border-r border-slate-800/60 bg-slate-950/20\">\n          \n          {/* Simulated Video Preview / Cinema Box */}\n          <div className=\"aspect-video lg:h-[390px] w-full bg-slate-950 relative flex items-center justify-center border-b border-slate-800/80 overflow-hidden group\">\n            {/* Background cinematic blur */}\n            <div className=\"absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-slate-600 to-black z-0\"></div>\n            \n            {/* Active frame image with fade transition */}\n            <AnimatePresence mode=\"wait\">\n              <motion.img \n                key={activeShot.id}\n                src={activeShot.imageUrl} \n                alt={activeShot.movement}\n                className=\"absolute inset-0 w-full h-full object-cover select-none z-10 brightness-[0.85] contrast-[1.05]\"\n                initial={{ opacity: 0, scale: 1.02 }}\n                animate={{ opacity: 1, scale: 1 }}\n                exit={{ opacity: 0 }}\n                transition={{ duration: 0.4 }}\n                referrerPolicy=\"no-referrer\"\n              />\n            </AnimatePresence>\n\n            {/* Cinematic overlay grids */}\n            <div className=\"absolute inset-0 border-[16px] border-black/40 z-20 pointer-events-none\"></div>\n            <div className=\"absolute top-6 left-6 z-20 bg-black/60 backdrop-blur-md px-3 py-1 rounded-md border border-white/10 text-xs font-mono tracking-wider flex items-center gap-2 text-white\">\n              <span className=\"w-2 h-2 bg-red-500 rounded-full animate-ping\"></span>\n              <span>LIVE REPLAY</span>\n            </div>\n\n            {/* Video overlay watermark/time */}\n            <div className=\"absolute bottom-6 right-6 z-20 bg-black/60 backdrop-blur-md px-3 py-1 rounded-md border border-white/10 text-xs font-mono text-white\">\n              {formatTime(currentTime)} / 05:37\n            </div>\n\n            {/* Interactive Quick Action Rail in Player Overlay */}\n            <div className=\"absolute bottom-6 left-6 z-20 flex items-center gap-2\">\n              <button \n                onClick={() => setIsPlaying(!isPlaying)}\n                className=\"w-10 h-10 rounded-full bg-blue-600 hover:bg-blue-500 text-white flex items-center justify-center shadow-lg transition-transform hover:scale-105 active:scale-95 cursor-pointer\"\n              >\n                {isPlaying ? <Pause className=\"w-4 h-4 fill-white\" /> : <Play className=\"w-4 h-4 fill-white ml-0.5\" />}\n              </button>\n              <button \n                onClick={() => setAudioMuted(!audioMuted)}\n                className=\"w-8 h-8 rounded-full bg-slate-800/80 hover:bg-slate-700 text-white flex items-center justify-center backdrop-blur shadow transition-colors cursor-pointer\"\n              >\n                {audioMuted ? <VolumeX className=\"w-3.5 h-3.5\" /> : <Volume2 className=\"w-3.5 h-3.5\" />}\n              </button>\n            </div>\n\n            {/* Custom Interactive Waveform / Timeline Overlay */}\n            <div className=\"absolute bottom-0 left-0 right-0 h-2 bg-slate-900/90 z-20 cursor-pointer\" \n              onClick={(e) => {\n                const rect = e.currentTarget.getBoundingClientRect();\n                const clickX = e.clientX - rect.left;\n                const percentage = clickX / rect.width;\n                const targetSeconds = Math.floor(percentage * maxDuration);\n                setCurrentTime(targetSeconds);\n                \n                // Find matching shot\n                const matchingShot = [...videoAnalysisData.shots]\n                  .reverse()\n                  .find((shot) => shot.timeSeconds <= targetSeconds);\n                if (matchingShot) setActiveShot(matchingShot);\n              }}\n            >\n              <div \n                className=\"h-full bg-gradient-to-r from-blue-600 to-indigo-500 relative transition-all duration-300 shadow-[0_0_8px_rgba(59,130,246,0.5)]\"\n                style={{ width: `${(currentTime / maxDuration) * 100}%` }}\n              >\n                <div className=\"absolute right-0 top-1/2 -translate-y-1/2 w-3 h-3 bg-white rounded-full border-2 border-blue-600 shadow cursor-grab\"></div>\n              </div>\n            </div>\n          </div>\n\n          {/* Detailed Selected Shot Metadata Panel (High Density info display) */}\n          <div className=\"p-4 bg-slate-900/40 border-b border-slate-800/60\">\n            <div className=\"flex flex-col gap-2\">\n              <div className=\"flex items-center justify-between\">\n                <span className=\"text-[11px] font-mono text-blue-400 bg-blue-950/50 border border-blue-900/50 px-2 py-0.5 rounded uppercase tracking-wider\">\n                  \345\275\223\345\211\215\351\200\211\344\270\255\351\225\234\345\244\264 / {activeShot.timestamp}\n                </span>\n                <span className=\"text-[10px] font-mono text-slate-500\">\n                  EST. SECONDS: {activeShot.timeSeconds}s\n                </span>\n              </div>\n              <h2 className=\"text-base font-bold text-slate-100 tracking-tight flex items-center gap-2\">\n                <span className=\"text-blue-500\">\350\277\220\351\225\234\357\274\232</span>\n                {activeShot.movement}\n              </h2>\n              <div className=\"grid grid-cols-2 gap-3 mt-1.5\">\n                <div className=\"bg-slate-900/60 p-2.5 rounded-lg border border-slate-800/50\">\n                  <span className=\"text-[10px] text-slate-500 uppercase block mb-1 font-semibold tracking-wider\">\347\224\273\351\235\242\346\236\204\345\233\276 (Composition)</span>\n                  <p className=\"text-xs text-slate-300 font-medium leading-relaxed\">{activeShot.composition}</p>\n                </div>\n                <div className=\"bg-slate-900/60 p-2.5 rounded-lg border border-slate-800/50\">\n                  <span className=\"text-[10px] text-slate-500 uppercase block mb-1 font-semibold tracking-wider\">\346\203\205\347\273\252\345\237\272\350\260\203 (Tone/Emotion)</span>\n                  <p className=\"text-xs text-emerald-400 font-medium leading-relaxed\">{activeShot.emotion}</p>\n                </div>\n              </div>\n              <div className=\"bg-slate-950/40 p-3 rounded-lg border border-slate-800/30 mt-1\">\n                <span className=\"text-[10px] text-slate-500 uppercase block mb-1 font-semibold tracking-wider\">\347\224\273\351\235\242\346\213\206\350\247\243\344\270\216\345\211\247\346\203\205\350\257\264\346\230\216 (Details)</span>\n                <p className=\"text-xs text-slate-300 leading-relaxed font-normal\">{activeShot.description}</p>\n              </div>\n            </div>\n          </div>\n\n          {/* Quick Search & Filters Bar */}\n          <div className=\"px-4 py-3 bg-slate-900/30 border-b border-slate-800/50 flex flex-col sm:flex-row gap-2 justify-between items-center\">\n            <div className=\"relative w-full sm:w-64\">\n              <Search className=\"w-3.5 h-3.5 text-slate-500 absolute left-3 top-1/2 -translate-y-1/2\" />\n              <input \n                type=\"text\" \n                placeholder=\"\346\220\234\347\264\242\350\277\220\351\225\234/\346\236\204\345\233\276/\346\203\205\347\273\252...\"\n                value={searchQuery}\n                onChange={(e) => setSearchQuery(e.target.value)}\n                className=\"w-full bg-slate-950 text-slate-200 pl-9 pr-4 py-1.5 rounded-lg border border-slate-800 focus:outline-none focus:border-blue-500 text-xs transition-colors\"\n              />\n              {searchQuery && (\n                <button onClick={() => setSearchQuery(\"\")} className=\"absolute right-2.5 top-1/2 -translate-y-1/2 text-slate-500 hover:text-slate-300\">\n                  <X className=\"w-3 h-3\" />\n                </button>\n              )}\n            </div>\n            \n            <div className=\"flex items-center gap-1.5 w-full sm:w-auto overflow-x-auto self-start sm:self-auto pb-1 sm:pb-0\">\n              <span className=\"text-[10px] text-slate-500 font-bold uppercase tracking-wider whitespace-nowrap\">\347\255\233\351\200\211:</span>\n              {[\"all\", \"aerial\", \"close\", \"portal\"].map((cat) => (\n                <button\n                  key={cat}\n                  onClick={() => setFilterCategory(cat)}\n                  className={`px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider cursor-pointer border transition-colors ${\n                    filterCategory === cat \n                      ? \"bg-blue-600/10 text-blue-400 border-blue-500/30\" \n                      : \"bg-transparent text-slate-400 border-transparent hover:bg-slate-800 hover:text-slate-200\"\n                  }`}\n                >\n                  {cat === \"all\" ? \"\345\205\250\351\203\250\" : cat === \"aerial\" ? \"\350\210\252\346\213\215\" : cat === \"close\" ? \"\347\211\271\345\206\231\" : \"\347\251\277\350\266\212\351\227\250\"}\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* Shots Sequence Table (High Density scroll area) */}\n          <div className=\"flex-1 overflow-y-auto max-h-[350px] lg:max-h-none custom-scrollbar\">\n            <div className=\"bg-slate-950/50 px-4 py-2 text-[10px] uppercase tracking-widest font-bold text-slate-500 flex border-b border-slate-800 sticky top-0 z-10 bg-slate-950\">\n              <span className=\"w-16\">\346\227\266\351\227\264\346\210\263</span>\n              <span className=\"w-32 md:w-44 truncate\">\350\277\220\351\225\234\346\226\271\345\274\217</span>\n              <span className=\"w-24 md:w-32 truncate\">\347\224\273\351\235\242\346\236\204\345\233\276</span>\n              <span className=\"flex-1 truncate\">\346\203\205\347\273\252\345\237\272\350\260\203</span>\n            </div>\n            <div className=\"divide-y divide-slate-900\">\n              {filteredShots.length > 0 ? (\n                filteredShots.map((shot) => {\n                  const isActive = shot.id === activeShot.id;\n                  return (\n                    <div \n                      key={shot.id}\n                      onClick={() => handleShotClick(shot)}\n                      className={`flex px-4 py-3 items-center hover:bg-blue-950/10 cursor-pointer transition-colors ${\n                        isActive ? \"bg-blue-950/20 border-l-2 border-blue-500 pl-[14px]\" : \"border-l-2 border-transparent\"\n                      }`}\n                    >\n                      <span className={`w-16 text-xs font-mono font-medium ${isActive ? \"text-blue-400\" : \"text-slate-500\"}`}>\n                        {shot.timestamp.split(\" - \")[0]}\n                      </span>\n                      <span className={`w-32 md:w-44 text-xs font-medium truncate pr-2 ${isActive ? \"text-slate-100\" : \"text-slate-300\"}`}>\n                        {shot.movement}\n                      </span>\n                      <span className=\"w-24 md:w-32 text-xs text-slate-400 font-mono truncate pr-2\">\n                        {shot.composition}\n                      </span>\n                      <span className={`flex-1 text-xs truncate ${isActive ? \"text-emerald-400\" : \"text-slate-400\"}`}>\n                        {shot.emotion}\n                      </span>\n                    </div>\n                  );\n                })\n              ) : (\n                <div className=\"p-8 text-center text-slate-500 text-xs\">\n                  \346\234\252\346\211\276\345\210\260\345\214\271\351\205\215\347\232\204\350\247\206\351\242\221\351\225\234\345\244\264\346\225\260\346\215\256\343\200\202\n                </div>\n              )}\n            </div>\n          </div>\n        </section>\n\n        {/* Right Column: Narrative Analysis & Character Dossier */}\n        <section className=\"flex-1 flex flex-col bg-slate-900/30 overflow-y-auto custom-scrollbar\">\n          \n          {/* Tabs header */}\n          <div className=\"h-12 border-b border-slate-800/80 bg-slate-900/50 flex items-center justify-between px-6 sticky top-0 z-10 backdrop-blur\">\n            <div className=\"flex gap-4\">\n              <button \n                onClick={() => setActiveTab(\"shots\")}\n                className={`h-12 text-xs font-bold uppercase tracking-widest border-b-2 transition-colors cursor-pointer ${\n                  activeTab === \"shots\" \n                    ? \"border-blue-500 text-slate-100\" \n                    : \"border-transparent text-slate-500 hover:text-slate-300\"\n                }`}\n              >\n                \351\225\234\345\244\264\346\246\202\350\247\210\n              </button>\n              <button \n                onClick={() => setActiveTab(\"characters\")}\n                className={`h-12 text-xs font-bold uppercase tracking-widest border-b-2 transition-colors cursor-pointer ${\n                  activeTab === \"characters\" \n                    ? \"border-purple-500 text-slate-100\" \n                    : \"border-transparent text-slate-500 hover:text-slate-300\"\n                }`}\n              >\n                \350\247\222\350\211\262\347\224\273\345\203\217\n              </button>\n              <button \n                onClick={() => setActiveTab(\"narrative\")}\n                className={`h-12 text-xs font-bold uppercase tracking-widest border-b-2 transition-colors cursor-pointer ${\n                  activeTab === \"narrative\" \n                    ? \"border-amber-500 text-slate-100\" \n                    : \"border-transparent text-slate-500 hover:text-slate-300\"\n                }`}\n              >\n                \345\217\231\344\272\213\344\270\216\347\210\275\347\202\271\n              </button>\n            </div>\n\n            <div className=\"text-[10px] font-mono text-slate-500 uppercase tracking-widest hidden md:block\">\n              WORKSPACE ACTIVE\n            </div>\n          </div>\n\n          <div className=\"p-6 flex-1 flex flex-col gap-6\">\n            \n            {/* TAB: SHOTS BRIEF */}\n            {activeTab === \"shots\" && (\n              <div className=\"space-y-6\">\n                <div>\n                  <h3 className=\"text-xs font-bold text-blue-400 uppercase tracking-widest mb-3 flex items-center\">\n                    <span className=\"w-1.5 h-1.5 bg-blue-400 rounded-full mr-2\"></span>\n                    \350\247\206\351\242\221\351\225\234\345\244\264\347\273\237\350\256\241\n                  </h3>\n                  <div className=\"grid grid-cols-3 gap-3\">\n                    <div className=\"bg-slate-900/50 p-3 rounded-lg border border-slate-800/60 text-center\">\n                      <span className=\"text-[10px] text-slate-500 block uppercase font-mono\">\351\225\234\345\244\264\346\200\273\346\225\260</span>\n                      <span className=\"text-xl font-bold text-slate-100 font-mono mt-0.5 block\">17</span>\n                    </div>\n                    <div className=\"bg-slate-900/50 p-3 rounded-lg border border-slate-800/60 text-center\">\n                      <span className=\"text-[10px] text-slate-500 block uppercase font-mono\">\345\271\263\345\235\207\347\247\222\346\225\260</span>\n                      <span className=\"text-xl font-bold text-slate-100 font-mono mt-0.5 block\">3.1s</span>\n                    </div>\n                    <div className=\"bg-slate-900/50 p-3 rounded-lg border border-slate-800/60 text-center\">\n                      <span className=\"text-[10px] text-slate-500 block uppercase font-mono\">\350\247\206\350\247\211\347\273\264\345\272\246</span>\n                      <span className=\"text-xl font-bold text-emerald-400 font-mono mt-0.5 block\">5\344\270\252</span>\n                    </div>\n                  </div>\n                </div>\n\n                <div>\n                  <h3 className=\"text-xs font-bold text-blue-400 uppercase tracking-widest mb-3 flex items-center\">\n                    <span className=\"w-1.5 h-1.5 bg-blue-400 rounded-full mr-2\"></span>\n                    \347\251\272\351\227\264\344\270\216\347\273\264\345\272\246\347\251\277\346\242\255\351\223\276\350\267\257 (Dimensional Pathway)\n                  </h3>\n                  <div className=\"bg-slate-900/40 p-4 rounded-xl border border-slate-800/60 space-y-4 font-mono text-xs\">\n                    <div className=\"flex items-center gap-2\">\n                      <div className=\"w-6 h-6 rounded-full bg-slate-800 flex items-center justify-center text-slate-400 font-bold\">1</div>\n                      <div className=\"flex-1\">\n                        <span className=\"text-slate-200 font-semibold\">\344\272\221\346\265\267\350\222\270\346\261\275\351\243\236\347\251\272\350\211\207 (Cabin Room)</span>\n                        <p className=\"text-[11px] text-slate-500 mt-0.5\">\345\257\271\350\257\235\346\213\214\345\230\264\357\274\214\345\273\272\347\253\213\345\260\217\351\230\237\351\273\230\345\245\221\344\270\216\346\200\247\346\240\274\345\217\215\345\267\256</p>\n                      </div>\n                    </div>\n                    <div className=\"h-6 w-0.5 bg-slate-800 ml-3\"></div>\n                    <div className=\"flex items-center gap-2\">\n                      <div className=\"w-6 h-6 rounded-full bg-slate-800 flex items-center justify-center text-slate-400 font-bold\">2</div>\n                      <div className=\"flex-1\">\n                        <span className=\"text-slate-200 font-semibold\">\344\270\207\347\261\263\346\236\201\351\200\237\351\253\230\347\251\272\351\200\237\351\231\215 (Skydive)</span>\n                        <p className=\"text-[11px] text-slate-500 mt-0.5\">\345\212\250\344\275\234\344\270\216\346\220\236\347\254\221\345\205\274\345\244\207\347\232\204\350\207\252\347\224\261\350\220\275\344\275\223\346\273\221\350\241\214</p>\n                      </div>\n                    </div>\n                    <div className=\"h-6 w-0.5 bg-slate-800 ml-3\"></div>\n                    <div className=\"flex items-center gap-2\">\n                      <div className=\"w-6 h-6 rounded-full bg-blue-600/20 text-blue-400 flex items-center justify-center font-bold border border-blue-500/30\">3</div>\n                      <div className=\"flex-1\">\n                        <span className=\"text-blue-400 font-semibold\">\345\267\215\345\263\250\351\233\252\345\261\261\346\273\221\351\233\252\347\211\271\346\212\200 (Snow Slope)</span>\n                        <p className=\"text-[11px] text-slate-500 mt-0.5\">\347\254\254\344\270\200\351\201\223\346\227\266\347\251\272\344\274\240\351\200\201\351\227\250\357\274\214\345\260\221\345\245\263\344\270\235\346\273\221\346\273\221\351\233\252</p>\n                      </div>\n                    </div>\n                    <div className=\"h-6 w-0.5 bg-slate-800 ml-3\"></div>\n                    <div className=\"flex items-center gap-2\">\n                      <div className=\"w-6 h-6 rounded-full bg-blue-600/20 text-blue-400 flex items-center justify-center font-bold border border-blue-500/30\">4</div>\n                      <div className=\"flex-1\">\n                        <span className=\"text-blue-400 font-semibold\">\346\267\261\346\265\267\347\273\232\344\270\275\347\217\212\347\221\232\347\276\244 (Ocean Deep)</span>\n                        <p className=\"text-[11px] text-slate-500 mt-0.5\">\347\254\254\344\272\214\351\201\223\344\274\240\351\200\201\351\227\250\357\274\214\345\224\257\347\276\216\346\262\273\346\204\210\347\211\251\350\264\250\350\275\254\350\264\250</p>\n                      </div>\n                    </div>\n                    <div className=\"h-6 w-0.5 bg-slate-800 ml-3\"></div>\n                    <div className=\"flex items-center gap-2\">\n                      <div className=\"w-6 h-6 rounded-full bg-purple-600/20 text-purple-400 flex items-center justify-center font-bold border border-purple-500/30\">5</div>\n                      <div className=\"flex-1\">\n                        <span className=\"text-purple-400 font-semibold\">\346\242\246\345\271\273\347\263\226\346\236\234\347\216\213\345\233\275 (Candy Land)</span>\n                        <p className=\"text-[11px] text-slate-500 mt-0.5\">\347\254\254\344\270\211\351\201\223\344\274\240\351\200\201\351\227\250\357\274\214\347\213\202\346\254\242\350\215\222\350\257\236\350\211\262\345\275\251\347\242\260\346\222\236</p>\n                      </div>\n                    </div>\n                    <div className=\"h-6 w-0.5 bg-slate-800 ml-3\"></div>\n                    <div className=\"flex items-center gap-2\">\n                      <div className=\"w-6 h-6 rounded-full bg-amber-600/20 text-amber-400 flex items-center justify-center font-bold border border-amber-500/30\">6</div>\n                      <div className=\"flex-1\">\n                        <span className=\"text-amber-400 font-semibold\">\350\277\234\345\217\244\351\201\227\350\277\271\345\272\237\345\242\237\345\206\263\346\210\230 (Desert Ruins)</span>\n                        <p className=\"text-[11px] text-slate-500 mt-0.5\">\347\254\254\345\233\233\351\201\223\344\274\240\351\200\201\351\227\250\357\274\214\347\203\255\350\241\200\345\206\263\346\210\230\345\274\202\345\275\242\346\200\252\345\205\275\345\206\233\345\233\242</p>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            )}\n\n            {/* TAB: CHARACTERS */}\n            {activeTab === \"characters\" && (\n              <div className=\"space-y-4\">\n                <h3 className=\"text-xs font-bold text-purple-400 uppercase tracking-widest mb-3 flex items-center\">\n                  <span className=\"w-1.5 h-1.5 bg-purple-400 rounded-full mr-2\"></span>\n                  \346\216\242\351\231\251\345\260\217\351\230\237\346\210\220\345\221\230\347\224\273\345\203\217 (Characters Dossier)\n                </h3>\n                \n                <div className=\"grid grid-cols-1 gap-4\">\n                  {videoAnalysisData.characters.map((char) => (\n                    <div \n                      key={char.name}\n                      onClick={() => setSelectedCharacter(char)}\n                      className=\"flex items-start gap-4 p-4 bg-slate-900/60 hover:bg-slate-800/60 rounded-xl border border-slate-800 hover:border-purple-500/40 transition-all cursor-pointer group\"\n                    >\n                      <div className=\"w-16 h-16 rounded-xl bg-slate-800 flex-shrink-0 border border-white/10 overflow-hidden relative shadow-inner\">\n                        <img \n                          src={char.avatarUrl} \n                          alt={char.name} \n                          className=\"w-full h-full object-cover transition-transform group-hover:scale-105\"\n                          referrerPolicy=\"no-referrer\"\n                        />\n                      </div>\n                      <div className=\"flex-1 min-w-0\">\n                        <div className=\"flex items-center justify-between gap-2 mb-1\">\n                          <h4 className=\"text-sm font-bold text-white group-hover:text-purple-400 transition-colors\">{char.name}</h4>\n                          <span className=\"text-[10px] px-2 py-0.5 bg-purple-950/60 text-purple-300 border border-purple-800/50 rounded-full font-medium\">\n                            {char.role.split(\" (\")[0]}\n                          </span>\n                        </div>\n                        <p className=\"text-xs text-slate-300 line-clamp-2 leading-relaxed\">{char.personality}</p>\n                        <p className=\"text-[11px] text-slate-500 mt-1.5 truncate italic\">\346\234\215\350\243\205\357\274\232{char.clothing}</p>\n                        \n                        <div className=\"flex flex-wrap gap-1.5 mt-2.5\">\n                          {char.skills.slice(0, 2).map((skill) => (\n                            <span key={skill} className=\"text-[9px] px-1.5 py-0.5 bg-slate-950 text-slate-400 rounded font-mono\">\n                              {skill}\n                            </span>\n                          ))}\n                        </div>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              </div>\n            )}\n\n            {/* TAB: NARRATIVE & INSIGHTS */}\n            {activeTab === \"narrative\" && (\n              <div className=\"space-y-5\">\n                <div>\n                  <h3 className=\"text-xs font-bold text-amber-400 uppercase tracking-widest mb-3 flex items-center\">\n                    <span className=\"w-1.5 h-1.5 bg-amber-400 rounded-full mr-2\"></span>\n                    \346\225\205\344\272\213\347\273\223\346\236\204\346\213\206\350\247\243 (Narrative Arc)\n                  </h3>\n                  <div className=\"bg-slate-900/50 p-4 rounded-xl border border-slate-800/80\">\n                    <p className=\"text-xs text-slate-300 leading-relaxed font-normal\">\n                      {videoAnalysisData.narrative.structure}\n                    </p>\n                  </div>\n                </div>\n\n                <div>\n                  <h3 className=\"text-xs font-bold text-amber-400 uppercase tracking-widest mb-3 flex items-center\">\n                    <span className=\"w-1.5 h-1.5 bg-amber-400 rounded-full mr-2\"></span>\n                    \350\247\206\345\220\254\345\211\252\350\276\221\350\212\202\345\245\217 (Edit & Audio Rhythm)\n                  </h3>\n                  <div className=\"bg-slate-900/50 p-4 rounded-xl border border-slate-800/80\">\n                    <p className=\"text-xs text-slate-300 leading-relaxed font-normal\">\n                      {videoAnalysisData.narrative.rhythm}\n                    </p>\n                  </div>\n                </div>\n\n                <div>\n                  <h3 className=\"text-xs font-bold text-amber-400 uppercase tracking-widest mb-3 flex items-center\">\n                    <span className=\"w-1.5 h-1.5 bg-amber-400 rounded-full mr-2\"></span>\n                    \347\274\226\345\211\247\347\210\206\347\202\271\344\270\216\347\210\275\347\202\271\350\256\276\350\256\241 (Spectacle Design)\n                  </h3>\n                  <div className=\"bg-slate-900/50 p-4 rounded-xl border border-slate-800/80\">\n                    <p className=\"text-xs text-slate-300 leading-relaxed font-normal\">\n                      {videoAnalysisData.narrative.climaxDesign}\n                    </p>\n                  </div>\n                </div>\n              </div>\n            )}\n\n          </div>\n\n          {/* Bottom stats inside section */}\n          <div className=\"p-4 bg-slate-950/40 border-t border-slate-800/60 grid grid-cols-2 gap-4 text-center\">\n            <div className=\"text-[10px] font-mono text-slate-500\">\n              ANALYZER ENGINE: <span className=\"text-blue-500\">GEMINI-3.5-FLASH</span>\n            </div>\n            <div className=\"text-[10px] font-mono text-slate-500\">\n              AUDIO CHANNEL: <span className=\"text-emerald-500\">STEREO PRO</span>\n            </div>\n          </div>\n        </section>\n      </main>\n\n      {/* Main Footer */}\n      <footer className=\"h-8 bg-slate-950 border-t border-slate-900 px-6 flex items-center justify-between text-[10px] font-mono text-slate-500 sticky bottom-0 z-40 bg-slate-950/90 backdrop-blur-sm\">\n        <div className=\"flex gap-6\">\n          <span>GPU ACCELERATION: ON</span>\n          <span className=\"hidden sm:inline\">NEURAL INTEL ENGINE: V4-STABLE</span>\n          <span>FPS: 60.00</span>\n        </div>\n        <div>\302\251 2026 AI VIDEO WORKBENCH \342\200\242 PROCESSED LATENCY: 24MS</div>\n      </footer>\n\n      {/* CHARACTER DETAILS DRAWER / MODAL */}\n      <AnimatePresence>\n        {selectedCharacter && (\n          <div className=\"fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4\">\n            <motion.div \n              initial={{ scale: 0.95, opacity: 0 }}\n              animate={{ scale: 1, opacity: 1 }}\n              exit={{ scale: 0.95, opacity: 0 }}\n              className=\"bg-slate-900 border border-slate-800 rounded-2xl max-w-lg w-full overflow-hidden shadow-2xl relative\"\n            >\n              <button \n                onClick={() => setSelectedCharacter(null)}\n                className=\"absolute top-4 right-4 text-slate-400 hover:text-white cursor-pointer w-8 h-8 rounded-full bg-slate-950/50 flex items-center justify-center border border-white/5\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n\n              <div className=\"p-6\">\n                <div className=\"flex gap-4 items-start\">\n                  <img \n                    src={selectedCharacter.avatarUrl} \n                    alt={selectedCharacter.name} \n                    className=\"w-20 h-20 rounded-xl object-cover border border-white/10 shadow-lg\"\n                    referrerPolicy=\"no-referrer\"\n                  />\n                  <div>\n                    <h3 className=\"text-lg font-bold text-white mb-0.5\">{selectedCharacter.name}</h3>\n                    <p className=\"text-xs text-purple-400 font-mono font-medium\">{selectedCharacter.role}</p>\n                    <p className=\"text-[11px] text-slate-500 mt-1 italic\">\346\234\215\351\245\260\357\274\232{selectedCharacter.clothing}</p>\n                  </div>\n                </div>\n\n                <div className=\"mt-6 space-y-4\">\n                  <div>\n                    <span className=\"text-[10px] font-mono text-slate-500 uppercase block mb-1\">\346\200\247\346\240\274\344\270\216\345\256\232\344\275\215</span>\n                    <p className=\"text-xs text-slate-300 leading-relaxed bg-slate-950/40 p-3 rounded-lg border border-slate-800/50\">\n                      {selectedCharacter.personality}\n                    </p>\n                  </div>\n\n                  <div>\n                    <span className=\"text-[10px] font-mono text-slate-500 uppercase block mb-1\">\347\273\217\345\205\270\345\217\260\350\257\215 / Banter Quote</span>\n                    <p className=\"text-xs text-purple-300 italic font-medium bg-purple-950/20 p-3 rounded-lg border border-purple-900/30\">\n                      &ldquo;{selectedCharacter.quote}&rdquo;\n                    </p>\n                  </div>\n\n                  <div>\n                    <span className=\"text-[10px] font-mono text-slate-500 uppercase block mb-1.5\">\346\240\270\345\277\203\350\203\275\345\212\233\344\270\216\346\240\207\347\255\276</span>\n                    <div className=\"flex flex-wrap gap-2\">\n                      {selectedCharacter.skills.map((skill) => (\n                        <span key={skill} className=\"text-xs px-2.5 py-1 bg-slate-950 border border-slate-800 text-slate-300 rounded-full font-mono\">\n                          {skill}\n                        </span>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </motion.div>\n          </div>\n        )}\n      </AnimatePresence>\n\n      {/* JSON REPORT MODAL */}\n      <AnimatePresence>\n        {showJsonModal && (\n          <div className=\"fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4\">\n            <motion.div \n              initial={{ scale: 0.95, opacity: 0 }}\n              animate={{ scale: 1, opacity: 1 }}\n              exit={{ scale: 0.95, opacity: 0 }}\n              className=\"bg-slate-900 border border-slate-800 rounded-2xl max-w-3xl w-full max-h-[85vh] flex flex-col overflow-hidden shadow-2xl relative\"\n            >\n              {/* Modal header */}\n              <div className=\"p-4 border-b border-slate-800 flex items-center justify-between bg-slate-900/50\">\n                <div className=\"flex items-center gap-2\">\n                  <FileJson className=\"w-5 h-5 text-blue-500\" />\n                  <h3 className=\"text-sm font-bold text-white\">\350\247\206\351\242\221\346\231\272\350\203\275\345\210\206\346\236\220\347\273\223\346\236\234 (\344\270\255\346\226\207 JSON \346\212\245\345\221\212)</h3>\n                </div>\n                <div className=\"flex items-center gap-2\">\n                  <button \n                    onClick={handleCopyJson}\n                    className=\"p-1.5 bg-slate-800 hover:bg-slate-700 text-slate-300 rounded hover:text-white transition-colors cursor-pointer text-xs flex items-center gap-1.5 px-3 border border-slate-700/50\"\n                  >\n                    {copied ? <Check className=\"w-3.5 h-3.5 text-emerald-400\" /> : <Copy className=\"w-3.5 h-3.5\" />}\n                    <span>{copied ? \"\345\267\262\345\244\215\345\210\266\" : \"\345\244\215\345\210\266\"}</span>\n                  </button>\n                  <button \n                    onClick={handleDownloadJson}\n                    className=\"p-1.5 bg-blue-600 hover:bg-blue-500 text-white rounded transition-colors cursor-pointer text-xs flex items-center gap-1.5 px-3\"\n                  >\n                    <Download className=\"w-3.5 h-3.5\" />\n                    <span>\344\270\213\350\275\275 JSON</span>\n                  </button>\n                  <button \n                    onClick={() => setShowJsonModal(false)}\n                    className=\"p-1.5 bg-slate-800 hover:bg-slate-700 text-slate-400 rounded hover:text-white transition-colors cursor-pointer\"\n                  >\n                    <X className=\"w-3.5 h-3.5\" />\n                  </button>\n                </div>\n              </div>\n\n              {/* Code Container */}\n              <div className=\"flex-1 overflow-y-auto p-4 bg-slate-950 font-mono text-[11px] leading-relaxed select-text custom-scrollbar\">\n                <pre className=\"text-blue-300\">\n                  {jsonString}\n                </pre>\n              </div>\n\n              {/* Modal Footer */}\n              <div className=\"p-3 border-t border-slate-800 bg-slate-900 text-center text-[10px] text-slate-500 font-mono\">\n                \347\254\246\345\220\210\350\246\201\346\261\202\347\232\204\344\270\255\346\226\207\345\210\206\346\236\220\346\236\266\346\236\204\357\274\214\345\214\205\345\220\253 shots \346\213\206\350\247\243\343\200\201characters \350\247\222\350\211\262\345\217\212 narrative \345\217\231\344\272\213\345\211\226\346\236\220\343\200\202\n              </div>\n            </motion.div>\n          </div>\n        )}\n      </AnimatePresence>\n    </div>\n  );\n}\n"
    }
